---
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  noindex?: boolean
  canonicalUrl?: string
}

const { title, description, noindex = false, canonicalUrl } = Astro.props
// Astro.site is the deploy origin; BASE_URL is the subpath ('/Pilot.BM/' on GitHub Pages, '/' on a root domain).
const origin = Astro.site?.origin ?? 'https://mcorbett51090.github.io'
const homeUrl = new URL(import.meta.env.BASE_URL, origin).href
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, origin).href

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Pilot.BM',
  url: homeUrl,
  description:
    'Bermuda, honestly. The guide for discerning visitors, people making the move, and those who call it home.',
  logo: new URL(`${import.meta.env.BASE_URL}favicon.svg`, origin).href,
  sameAs: [],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Pilot.BM</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/Pilot.BM/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Pilot.BM`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pilot.BM" />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Analytics seam — replace with real script tag once provider is chosen -->
    <!-- TODO: Choose Plausible ($9/mo, privacy-first) or Cloudflare Web Analytics (free) -->
    <!-- Plausible: <script defer data-domain="pilot.bm" src="https://plausible.io/js/script.js"></script> -->
    <!-- Cloudflare: <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "TODO_CF_TOKEN"}'></script> -->
    <!-- PLACEHOLDER — analytics not yet active. Wire after domain + provider confirmed. -->

    <!-- Named slot for page-level head injection (e.g. FAQPage schema) -->
    <slot name="head" />
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Platform-aware map links: route Apple-device users via Apple Maps (their
         default app); everyone else keeps the Google Maps href. Progressive
         enhancement — links work fine without this script. -->
    <script is:inline>
      ;(function () {
        var ua = navigator.userAgent || ''
        var isApple = /iPhone|iPad|iPod|Macintosh|Mac OS X/.test(ua)
        if (!isApple) return
        document.querySelectorAll('a[data-map-query]').forEach(function (a) {
          var q = a.getAttribute('data-map-query')
          if (q) a.href = 'https://maps.apple.com/?q=' + encodeURIComponent(q)
        })
      })()
    </script>
  </body>
</html>
