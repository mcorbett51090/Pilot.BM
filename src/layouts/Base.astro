---
import Navigation from '../components/Navigation.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  noindex?: boolean
  canonicalUrl?: string
}

const { title, description, noindex = false, canonicalUrl } = Astro.props
const siteUrl = 'https://pilot.bm'
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Pilot.BM',
  url: siteUrl,
  description:
    'Bermuda, honestly. The guide for discerning visitors, people making the move, and those who call it home.',
  logo: `${siteUrl}/favicon.svg`,
  sameAs: [],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Pilot.BM</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Pilot.BM`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pilot.BM" />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Named slot for page-level head injection (e.g. FAQPage schema) -->
    <slot name="head" />
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
