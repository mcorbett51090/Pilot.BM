---
import Base from '../layouts/Base.astro'
import { searchIndex } from '../data/search-index.ts'

// Build the client payload: prefix every url with the deploy base
// (import.meta.env.BASE_URL is '/Pilot.BM/' on Pages, '/' on the root domain),
// collapsing any accidental double slash. This keeps the index base-path-safe.
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const clientIndex = searchIndex.map((e) => ({
  t: e.title,
  d: e.description,
  s: e.section,
  k: e.keywords,
  u: `${base}${e.url}`.replace(/\/{2,}/g, '/'),
}))
---

<Base
  title="Search"
  description="Search Pilot.BM — find guides on visiting, moving to, and living in Bermuda: getting around, beaches, work permits, cost of living, schools, insurance, climate, and more."
  noindex={true}
>
  <section class="hero" style="padding-block: var(--space-12);">
    <div class="hero__inner">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" style="justify-content: center; color: rgba(255,255,255,0.6);">
          <li><a href={`${base}/`} style="color: rgba(255,255,255,0.6);">Home</a></li>
          <li class="breadcrumb__sep" aria-hidden="true">›</li>
          <li style="color: rgba(255,255,255,0.9);">Search</li>
        </ol>
      </nav>
      <h1 class="hero-title" style="font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));">Search Pilot.BM</h1>
      <p class="hero-subtitle">
        Find the answer across every guide — visiting, moving, and living in Bermuda.
      </p>
    </div>
  </section>

  <div class="container" style="padding-block: var(--space-12);">
    <div style="max-width: 760px; margin: 0 auto;">
      <form id="search-form" role="search" class="search-box" autocomplete="off" onsubmit="return false;">
        <label for="search-input" class="visually-hidden">Search Pilot.BM</label>
        <span class="search-box__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </span>
        <input
          type="search"
          id="search-input"
          name="q"
          class="search-box__input"
          placeholder="Try “scooter”, “pink sand”, “work permit”, “SHB”, “climate”…"
          aria-describedby="search-status"
          autofocus
        />
      </form>

      <p id="search-status" class="search-status" aria-live="polite" role="status"></p>

      <!-- Suggested searches, shown before the user types -->
      <div id="search-suggestions" class="search-suggestions">
        <p class="search-suggestions__label">Popular searches</p>
        <div class="search-suggestions__chips">
          <button type="button" class="search-chip" data-q="getting around">Getting around</button>
          <button type="button" class="search-chip" data-q="beaches">Beaches</button>
          <button type="button" class="search-chip" data-q="best time to visit">Best time to visit</button>
          <button type="button" class="search-chip" data-q="cost of living">Cost of living</button>
          <button type="button" class="search-chip" data-q="work permit">Work permit</button>
          <button type="button" class="search-chip" data-q="insurance">Insurance</button>
          <button type="button" class="search-chip" data-q="schools">Schools</button>
          <button type="button" class="search-chip" data-q="statistics">Statistics</button>
        </div>
      </div>

      <ul id="search-results" class="search-results" role="list"></ul>
    </div>
  </div>

  <script type="application/json" id="search-data" set:html={JSON.stringify(clientIndex)} />

  <script is:inline>
    ;(function () {
      var INDEX = JSON.parse(document.getElementById('search-data').textContent)
      var input = document.getElementById('search-input')
      var resultsEl = document.getElementById('search-results')
      var statusEl = document.getElementById('search-status')
      var suggestionsEl = document.getElementById('search-suggestions')

      function escapeHtml(s) {
        return s.replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
        })
      }

      // Score one entry against the lowercased query tokens.
      function score(entry, tokens) {
        var title = entry.t.toLowerCase()
        var keywords = entry.k.toLowerCase()
        var desc = entry.d.toLowerCase()
        var total = 0
        for (var i = 0; i < tokens.length; i++) {
          var tok = tokens[i]
          if (!tok) continue
          var hit = 0
          if (title.indexOf(tok) !== -1) hit += title.indexOf(tok) === 0 ? 12 : 8
          if (keywords.indexOf(tok) !== -1) hit += 5
          if (desc.indexOf(tok) !== -1) hit += 2
          // Every token must match somewhere, or this entry is out.
          if (hit === 0) return 0
          total += hit
        }
        return total
      }

      function render(query) {
        var q = query.trim().toLowerCase()
        if (!q) {
          resultsEl.innerHTML = ''
          statusEl.textContent = ''
          suggestionsEl.style.display = ''
          return
        }
        suggestionsEl.style.display = 'none'
        var tokens = q.split(/\s+/)
        var scored = []
        for (var i = 0; i < INDEX.length; i++) {
          var s = score(INDEX[i], tokens)
          if (s > 0) scored.push({ e: INDEX[i], s: s })
        }
        scored.sort(function (a, b) {
          return b.s - a.s
        })

        if (scored.length === 0) {
          resultsEl.innerHTML =
            '<li class="search-empty">' +
            '<p><strong>No matches for “' + escapeHtml(query) + '”.</strong></p>' +
            '<p>Try a broader term, or browse the <a href="' + INDEX[0].u + '">homepage</a>. ' +
            'You can also email <a href="mailto:matt@ravenpower.net">matt@ravenpower.net</a> and we’ll add it.</p>' +
            '</li>'
          statusEl.textContent = 'No results for “' + query + '”.'
          return
        }

        statusEl.textContent =
          scored.length + (scored.length === 1 ? ' result' : ' results') + ' for “' + query + '”.'

        var html = ''
        for (var j = 0; j < scored.length; j++) {
          var e = scored[j].e
          html +=
            '<li class="search-result">' +
            '<a href="' + e.u + '" class="search-result__link">' +
            '<span class="search-result__section">' + escapeHtml(e.s) + '</span>' +
            '<span class="search-result__title">' + escapeHtml(e.t) + '</span>' +
            '<span class="search-result__desc">' + escapeHtml(e.d) + '</span>' +
            '</a></li>'
        }
        resultsEl.innerHTML = html
      }

      // Debounce input for smoothness on slower devices.
      var timer = null
      input.addEventListener('input', function () {
        clearTimeout(timer)
        timer = setTimeout(function () {
          render(input.value)
          // Keep the URL shareable without reloading.
          try {
            var url = new URL(window.location.href)
            if (input.value.trim()) url.searchParams.set('q', input.value.trim())
            else url.searchParams.delete('q')
            window.history.replaceState({}, '', url)
          } catch (err) {}
        }, 120)
      })

      // Suggestion chips.
      var chips = document.querySelectorAll('.search-chip')
      for (var c = 0; c < chips.length; c++) {
        chips[c].addEventListener('click', function () {
          input.value = this.getAttribute('data-q')
          input.focus()
          render(input.value)
        })
      }

      // Hydrate from ?q= on load (shareable result links).
      try {
        var initial = new URL(window.location.href).searchParams.get('q')
        if (initial) {
          input.value = initial
          render(initial)
        }
      } catch (err) {}
    })()
  </script>

  <style>
    .search-box {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      border: 2px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-3) var(--space-5);
      background: var(--color-white);
      box-shadow: var(--shadow-sm);
      transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .search-box:focus-within {
      border-color: var(--color-ocean);
      box-shadow: 0 0 0 4px var(--color-ocean-muted);
    }
    .search-box__icon {
      color: var(--color-muted);
      display: flex;
      flex-shrink: 0;
    }
    .search-box__input {
      flex: 1;
      border: none;
      outline: none;
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      color: var(--color-ink);
      background: transparent;
      min-height: 32px;
    }
    .search-status {
      font-size: var(--text-sm);
      color: var(--color-muted);
      margin-top: var(--space-4);
      min-height: 1.2em;
    }
    .search-suggestions {
      margin-top: var(--space-6);
    }
    .search-suggestions__label {
      font-size: var(--text-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-ocean);
      margin-bottom: var(--space-3);
    }
    .search-suggestions__chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }
    .search-chip {
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      color: var(--color-ink);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      padding: var(--space-2) var(--space-4);
      min-height: 36px;
      cursor: pointer;
      transition: background-color var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
    }
    .search-chip:hover {
      background: var(--color-ocean-muted);
      border-color: var(--color-ocean);
      color: var(--color-ocean);
    }
    .search-results {
      list-style: none;
      margin-top: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .search-result__link {
      display: block;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-4) var(--space-5);
      text-decoration: none;
      color: var(--color-ink);
      transition: box-shadow var(--transition-base), border-color var(--transition-base), transform var(--transition-base);
    }
    .search-result__link:hover {
      box-shadow: var(--shadow-md);
      border-color: var(--color-ocean);
      transform: translateY(-1px);
      text-decoration: none;
    }
    .search-result__section {
      display: inline-block;
      font-size: var(--text-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-ocean);
      margin-bottom: var(--space-1);
    }
    .search-result__title {
      display: block;
      font-family: var(--font-serif);
      font-size: var(--text-lg);
      font-weight: 700;
      color: var(--color-ink);
      margin-bottom: var(--space-1);
    }
    .search-result__desc {
      display: block;
      font-size: var(--text-sm);
      color: var(--color-muted);
      line-height: 1.5;
    }
    .search-empty {
      list-style: none;
      border: 1px dashed var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      color: var(--color-muted);
      font-size: var(--text-sm);
    }
    .search-empty p {
      margin-bottom: var(--space-2);
      color: var(--color-muted);
    }
  </style>
</Base>
