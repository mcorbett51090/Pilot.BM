---
import Base from '../layouts/Base.astro'
import MediaMentions from '../components/MediaMentions.astro'
import Quotes from '../components/Quotes.astro'
---

<Base
  title="Bermuda, honestly"
  description="The independent guide to Bermuda for discerning visitors, people making the move, and those who call it home. Real answers to the questions every guide skips."
>
  <!-- Hero -->
  <section class="hero hero--image" style="--hero-image: url('/Pilot.BM/images/hero-horseshoe-bay.webp');">
    <div class="hero__inner">
      <h1 class="hero-title">Bermuda, honestly.</h1>
      <p class="hero-subtitle">
        The guide for discerning visitors, people making the move, and those who call it home.
      </p>
      <div class="hero-cta">
        <a href="/Pilot.BM/visit" class="btn btn-primary btn-lg">Plan Your Visit</a>
        <a href="/Pilot.BM/move" class="btn btn-secondary btn-lg" style="border-color: rgba(255,255,255,0.6); color: #ffffff;">
          Moving to Bermuda
        </a>
      </div>
    </div>
  </section>

  <!-- Audience cards -->
  <section class="section" style="background-color: var(--color-sand);">
    <div class="container">
      <span class="section-eyebrow">Who is Pilot.BM for?</span>
      <h2 class="section-title">The Bermuda guide you actually needed</h2>
      <p class="section-desc">
        Every other guide was either a tourism board brochure or a budget-backpacker blog.
        Neither answered the real questions. We built this to fill that gap.
      </p>

      <div class="card-grid card-grid-3">
        <!-- Visiting -->
        <a href="/Pilot.BM/visit" class="photo-card">
          <div class="photo-card__media">
            <img src="/Pilot.BM/images/beach-horseshoe.webp" alt="Pink-sand beach and turquoise water at Horseshoe Bay, Bermuda" width="800" height="500" loading="lazy" decoding="async" />
          </div>
          <div class="photo-card__body">
            <p class="photo-card__eyebrow">Visiting</p>
            <h3 class="photo-card__title">Planning a trip?</h3>
            <p class="photo-card__desc">
              How to get around without a rental car. Pink-sand beaches worth the trip.
              Where to eat without paying resort prices. What to actually do for a week.
            </p>
            <p class="photo-card__cta">Getting Around · Beaches · Eat &amp; Drink · Where to Stay →</p>
          </div>
        </a>

        <!-- Moving -->
        <a href="/Pilot.BM/move" class="photo-card">
          <div class="photo-card__media">
            <img src="/Pilot.BM/images/hamilton-harbour.webp" alt="View over Hamilton Harbour, Bermuda" width="800" height="500" loading="lazy" decoding="async" />
          </div>
          <div class="photo-card__body">
            <p class="photo-card__eyebrow">Moving</p>
            <h3 class="photo-card__title">Making the move?</h3>
            <p class="photo-card__desc">
              Work permits. The real cost of living (hint: it's higher than you think).
              The one-car-per-household rule nobody tells you about. What salary you actually need.
            </p>
            <p class="photo-card__cta">Work Permits · Cost of Living · Tools →</p>
          </div>
        </a>

        <!-- Living -->
        <a href="/Pilot.BM/live" class="photo-card">
          <div class="photo-card__media">
            <img src="/Pilot.BM/images/hamilton-town.webp" alt="Streets and rooftops of the City of Hamilton, Bermuda" width="800" height="500" loading="lazy" decoding="async" />
          </div>
          <div class="photo-card__body">
            <p class="photo-card__eyebrow">Living</p>
            <h3 class="photo-card__title">Already here?</h3>
            <p class="photo-card__desc">
              Local deals, events, and the things you discover after you've been here six months.
              The residents section is growing — more coming soon.
            </p>
            <p class="photo-card__cta">Directory · Events · Deals →</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Recognition strip -->
  <MediaMentions tone="plain" />

  <!-- Transport spotlight -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: center;">
        <div>
          <span class="section-eyebrow">The thing nobody tells visitors</span>
          <h2 class="section-title" style="font-size: var(--text-3xl);">
            You cannot rent a car in Bermuda.
          </h2>
          <p style="color: var(--color-muted); font-size: var(--text-lg); line-height: 1.7; margin-bottom: var(--space-6);">
            Bermuda is one of the few destinations in the world where rental cars for tourists are banned.
            The island allows one car per household — a quota that dates back decades.
            Scooters, electric minicars, buses, ferries, and taxis are your actual options.
          </p>
          <p style="color: var(--color-muted); margin-bottom: var(--space-6);">
            Our interactive tool matches you to the right transport for your trip, party size, and budget.
          </p>
          <a href="/Pilot.BM/visit/getting-around" class="btn btn-primary">
            See the Getting Around guide →
          </a>
        </div>
        <figure class="media-frame">
          <img src="/Pilot.BM/images/scooters.webp" alt="Scooters and motorcycles parked along a street in Hamilton, Bermuda" width="1600" height="1200" loading="lazy" decoding="async" />
          <figcaption class="media-frame__caption">
            Scooters are the most common way visitors get around — no rental car required.
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Directory CTA -->
  <section class="section section--photo" style="--section-image: url('/Pilot.BM/images/hamilton-harbour.webp');">
    <div class="container" style="text-align: center;">
      <span class="section-eyebrow" style="color: rgba(255,255,255,0.7);">Bermuda Directory</span>
      <h2 style="font-family: var(--font-serif); color: var(--color-white); margin-bottom: var(--space-4);">
        Browse Bermuda businesses
      </h2>
      <p style="color: rgba(255,255,255,0.8); font-size: var(--text-lg); max-width: 560px; margin: 0 auto var(--space-8);">
        Hotels, restaurants, transport, real estate, insurance, schools —
        curated and organised by audience. Free listings, verified information.
      </p>
      <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
        <a href="/Pilot.BM/directory" class="btn btn-primary" style="background-color: white; color: var(--color-ocean);">
          Browse Directory →
        </a>
        <a href="/Pilot.BM/directory/claim" class="btn btn-secondary" style="border-color: rgba(255,255,255,0.5); color: white;">
          Claim Your Listing
        </a>
      </div>
    </div>
  </section>

  <!-- Mover tools spotlight -->
  <section class="section" style="background-color: var(--color-sand);">
    <div class="container">
      <span class="section-eyebrow">For people making the move</span>
      <h2 class="section-title" style="font-size: var(--text-3xl);">Tools for movers</h2>
      <p class="section-desc">
        Moving to Bermuda is complicated. These tools cut through the complexity.
      </p>

      <div class="card-grid card-grid-3">
        <a href="/Pilot.BM/move/tools/assessment-number" class="photo-card">
          <div class="photo-card__media">
            <img src="/Pilot.BM/images/bus-stop.webp" alt="Pink bus-stop pole on a Bermuda roadside" width="800" height="500" loading="lazy" decoding="async" />
          </div>
          <div class="photo-card__body">
            <p class="photo-card__eyebrow">Tool</p>
            <h3 class="photo-card__title">The Car Trap</h3>
            <p class="photo-card__desc">
              One car per household. Assessment Numbers explained — and why this surprises almost every mover.
            </p>
          </div>
        </a>
        <a href="/Pilot.BM/move/tools/compensation" class="photo-card">
          <div class="photo-card__media">
            <img src="/Pilot.BM/images/hamilton-town.webp" alt="City of Hamilton, Bermuda" width="800" height="500" loading="lazy" decoding="async" />
          </div>
          <div class="photo-card__body">
            <p class="photo-card__eyebrow">Calculator</p>
            <h3 class="photo-card__title">What Salary Do You Need?</h3>
            <p class="photo-card__desc">
              Bermuda costs ~94% more than the US average. Calculate the gross salary you need to maintain your lifestyle.
            </p>
          </div>
        </a>
        <a href="/Pilot.BM/move/tools/pathway" class="photo-card">
          <div class="photo-card__media">
            <img src="/Pilot.BM/images/garden.webp" alt="Pathway through the Botanical Gardens, Bermuda" width="800" height="500" loading="lazy" decoding="async" />
          </div>
          <div class="photo-card__body">
            <p class="photo-card__eyebrow">Decision Tree</p>
            <h3 class="photo-card__title">Immigration Pathway Finder</h3>
            <p class="photo-card__desc">
              Do you qualify to move to Bermuda? Work through the decision tree — work permit, spousal, or EIRC.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Bermuda by the Numbers teaser -->
  <section class="section--photo" style="--section-image: url('/Pilot.BM/images/seascape.webp'); padding-block: var(--space-16);">
    <div class="container" style="text-align: center;">
      <span class="section-eyebrow" style="color: rgba(255,255,255,0.7);">Bermuda by the Numbers</span>
      <h2 style="font-family: var(--font-serif); color: var(--color-white); font-size: var(--text-3xl); margin-bottom: var(--space-8);">
        The island, in figures you can trust
      </h2>
      <div class="home-stats">
        <div class="home-stat">
          <span class="home-stat__value">63,356</span>
          <span class="home-stat__label">residents (2023)</span>
        </div>
        <div class="home-stat">
          <span class="home-stat__value">21%</span>
          <span class="home-stat__label">non-Bermudian (2016)</span>
        </div>
        <div class="home-stat">
          <span class="home-stat__value">~21</span>
          <span class="home-stat__label">square miles of island</span>
        </div>
        <div class="home-stat">
          <span class="home-stat__value">$550M</span>
          <span class="home-stat__label">visitor spend (2025)</span>
        </div>
      </div>
      <a href="/Pilot.BM/bermuda-by-the-numbers" class="btn btn-primary" style="background-color: white; color: var(--color-ocean); margin-top: var(--space-8);">
        See all the numbers (sourced) →
      </a>
    </div>
  </section>

  <!-- Notable quotes about Bermuda -->
  <Quotes limit={3} tone="sand" />

  <!-- Editorial voice / about nudge -->
  <section class="section">
    <div class="container" style="max-width: 720px; text-align: center;">
      <span class="section-eyebrow">Why Pilot.BM?</span>
      <h2 class="section-title" style="font-size: var(--text-3xl);">
        We'll tell you when things change.
      </h2>
      <p style="color: var(--color-muted); font-size: var(--text-lg); line-height: 1.7; margin-bottom: var(--space-6);">
        The Work From Bermuda digital-nomad programme closed on 28 February 2025.
        Most guides still describe it as available. We updated on the day it closed.
        That's the editorial standard Pilot.BM holds itself to.
      </p>
      <p style="color: var(--color-muted); margin-bottom: var(--space-8);">
        We research, we cite sources, we flag what's unverified, and we update when things change.
        Read more about who we are and how we work.
      </p>
      <a href="/Pilot.BM/about" class="btn btn-secondary">About Pilot.BM →</a>
    </div>
  </section>
</Base>

<style>
  @media (max-width: 767px) {
    section > .container > div[style*='grid-template-columns: 1fr 1fr'] {
      grid-template-columns: 1fr !important;
    }
  }

  /* Bermuda-by-the-numbers teaser stats */
  .home-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 720px;
    margin-inline: auto;
  }
  @media (min-width: 768px) {
    .home-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .home-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .home-stat__value {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1;
  }
  .home-stat__label {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.8);
  }
</style>
