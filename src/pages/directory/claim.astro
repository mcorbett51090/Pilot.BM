---
// TODO: Wire Stripe Checkout (Phase 2) — HMAC-signed claim tokens + webhook tier management.
// See docs/viability.md § FM-4 billing security seam.
import Base from '../../layouts/Base.astro'
---

<Base
  title="Claim Your Business on Pilot.BM"
  description="Add your Bermuda business to the Pilot.BM directory. Free listing available. Standard, Featured, and Anchor tiers for enhanced placement and partner badges."
>
  <section class="hero" style="padding-block: var(--space-16);">
    <div class="hero__inner">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" style="justify-content: center; color: rgba(255,255,255,0.6);">
          <li><a href="/" style="color: rgba(255,255,255,0.6);">Home</a></li>
          <li class="breadcrumb__sep" aria-hidden="true">›</li>
          <li><a href="/directory" style="color: rgba(255,255,255,0.6);">Directory</a></li>
          <li class="breadcrumb__sep" aria-hidden="true">›</li>
          <li style="color: rgba(255,255,255,0.9);">Claim a Listing</li>
        </ol>
      </nav>
      <h1 class="hero-title">Claim Your Listing</h1>
      <p class="hero-subtitle">
        Be found by the visitors, movers, and residents who need what you offer.
      </p>
    </div>
  </section>

  <div class="container" style="padding-block: var(--space-12);">

    <!-- Tier pricing -->
    <h2 style="text-align: center; margin-bottom: var(--space-4);">Choose your tier</h2>
    <p style="text-align: center; color: var(--color-muted); margin-bottom: var(--space-10);">
      All tiers include a listing in the Pilot.BM directory. Paid tiers include enhanced placement and features.
    </p>

    <div class="card-grid card-grid-4" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); margin-bottom: var(--space-12);">
      <!-- Free -->
      <div class="card" style="text-align: center;">
        <span class="badge badge-tier-free" style="margin-bottom: var(--space-4);">Free</span>
        <p style="font-family: var(--font-serif); font-size: var(--text-3xl); margin-bottom: var(--space-1);">$0</p>
        <p style="color: var(--color-muted); font-size: var(--text-sm); margin-bottom: var(--space-4);">per month</p>
        <ul style="text-align: left; font-size: var(--text-sm); color: var(--color-muted); padding-left: var(--space-5); margin-bottom: var(--space-4);">
          <li>Listed in directory</li>
          <li>Name + category</li>
          <li>Parish shown</li>
        </ul>
        <button class="btn btn-ghost btn-sm" onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
          Get listed free
        </button>
      </div>

      <!-- Standard -->
      <div class="card" style="text-align: center;">
        <span class="badge badge-tier-standard" style="margin-bottom: var(--space-4);">Standard</span>
        <p style="font-family: var(--font-serif); font-size: var(--text-3xl); margin-bottom: var(--space-1);">$30</p>
        <p style="color: var(--color-muted); font-size: var(--text-sm); margin-bottom: var(--space-4);">per month</p>
        <ul style="text-align: left; font-size: var(--text-sm); color: var(--color-muted); padding-left: var(--space-5); margin-bottom: var(--space-4);">
          <li>Everything in Free</li>
          <li>Full description</li>
          <li>Phone + website link</li>
          <li>Hours of operation</li>
        </ul>
        <button class="btn btn-secondary btn-sm" onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
          Get Standard
        </button>
      </div>

      <!-- Featured -->
      <div class="card card-elevated" style="text-align: center; border-color: var(--color-tier-featured); border-width: 2px;">
        <span class="badge badge-tier-featured" style="margin-bottom: var(--space-4);">Featured</span>
        <p style="font-family: var(--font-serif); font-size: var(--text-3xl); margin-bottom: var(--space-1);">$50</p>
        <p style="color: var(--color-muted); font-size: var(--text-sm); margin-bottom: var(--space-4);">per month</p>
        <ul style="text-align: left; font-size: var(--text-sm); color: var(--color-muted); padding-left: var(--space-5); margin-bottom: var(--space-4);">
          <li>Everything in Standard</li>
          <li>Top category placement</li>
          <li>Photos (up to 3)</li>
          <li>Pilot.BM Partner badge</li>
          <li>Homepage exposure</li>
        </ul>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
          Get Featured
        </button>
      </div>

      <!-- Anchor -->
      <div class="card" style="text-align: center; border-color: var(--color-tier-anchor); border-width: 2px;">
        <span class="badge badge-tier-anchor" style="margin-bottom: var(--space-4);">Anchor</span>
        <p style="font-family: var(--font-serif); font-size: var(--text-3xl); margin-bottom: var(--space-1);">$100</p>
        <p style="color: var(--color-muted); font-size: var(--text-sm); margin-bottom: var(--space-4);">per month</p>
        <ul style="text-align: left; font-size: var(--text-sm); color: var(--color-muted); padding-left: var(--space-5); margin-bottom: var(--space-4);">
          <li>Everything in Featured</li>
          <li>Category lead position</li>
          <li>Sidebar feature</li>
          <li>Newsletter placement</li>
          <li>Anchor Partner badge</li>
        </ul>
        <button class="btn btn-secondary btn-sm" onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
          Get Anchor
        </button>
      </div>
    </div>

    <!-- Claim form -->
    <div id="claim-form" style="max-width: 560px; margin: 0 auto;">
      <div id="form-view">
        <h2 style="text-align: center; margin-bottom: var(--space-2);">Claim your listing</h2>
        <p style="text-align: center; color: var(--color-muted); margin-bottom: var(--space-8);">
          We'll review your submission and be in touch within 24 hours.
        </p>

        <form id="claim-submission" style="display: flex; flex-direction: column; gap: var(--space-5);" onsubmit="return false;">
          <div>
            <label for="biz-name" style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Business name *
            </label>
            <input
              type="text"
              id="biz-name"
              required
              placeholder="Your business name"
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm);"
            />
          </div>

          <div>
            <label for="biz-email" style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Email address *
            </label>
            <input
              type="email"
              id="biz-email"
              required
              placeholder="you@example.com"
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm);"
            />
          </div>

          <div>
            <label for="biz-tier" style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Tier you're interested in *
            </label>
            <select
              id="biz-tier"
              required
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); background-color: var(--color-white);"
            >
              <option value="">Select a tier...</option>
              <option value="free">Free — Listed name + category</option>
              <option value="standard">Standard — $30/month, full profile</option>
              <option value="featured">Featured — $50/month, photos + Partner badge</option>
              <option value="anchor">Anchor — $100/month, category lead</option>
            </select>
          </div>

          <!-- TODO: Wire Stripe Checkout (Phase 2) — HMAC-signed claim tokens + webhook tier management -->
          <div style="background-color: var(--color-amber-muted); border: 1px solid var(--color-amber); border-radius: var(--radius-md); padding: var(--space-3) var(--space-4);">
            <p style="font-size: var(--text-xs); color: #92400e; margin: 0;">
              <strong>Phase 1:</strong> Payment processing is not yet live.
              We'll contact you with payment instructions after reviewing your submission.
              Billing (Stripe + automated onboarding) launches in Phase 2.
            </p>
          </div>

          <button type="button" id="submit-claim" class="btn btn-primary btn-lg" style="width: 100%;">
            Submit claim →
          </button>
        </form>
      </div>

      <!-- Thank you state -->
      <div id="thankyou-view" style="display: none; text-align: center; padding: var(--space-10);">
        <p style="font-size: var(--text-4xl); margin-bottom: var(--space-4);">✓</p>
        <h2 style="margin-bottom: var(--space-3);">We'll be in touch within 24 hours</h2>
        <p style="color: var(--color-muted); margin-bottom: var(--space-6);">
          Thank you for claiming your listing. We'll review your submission and reach out at the email you provided.
        </p>
        <a href="/directory" class="btn btn-secondary">Back to Directory</a>
      </div>
    </div>

  </div>
</Base>

<script>
  document.getElementById('submit-claim')?.addEventListener('click', () => {
    const form = document.getElementById('claim-submission') as HTMLFormElement
    if (!form) return

    const name = (document.getElementById('biz-name') as HTMLInputElement)?.value?.trim()
    const email = (document.getElementById('biz-email') as HTMLInputElement)?.value?.trim()
    const tier = (document.getElementById('biz-tier') as HTMLSelectElement)?.value

    if (!name || !email || !tier) {
      alert('Please fill in all required fields.')
      return
    }

    // Phase 2: POST to API endpoint
    // For now: show thank-you state
    const formView = document.getElementById('form-view')
    const thankYou = document.getElementById('thankyou-view')
    if (formView) formView.style.display = 'none'
    if (thankYou) thankYou.style.display = 'block'
  })
</script>
