---
// TODO: Wire Stripe Checkout (Phase 2) — HMAC-signed claim tokens + webhook tier management.
// See docs/monetization.md for integration instructions and the billing security seam.
import Base from '../../layouts/Base.astro'
---

<Base
  title="Claim Your Business on Pilot.BM"
  description="Add your Bermuda business to the Pilot.BM directory. Free listing available. Standard, Featured, and Anchor tiers for enhanced placement and partner benefits."
>
  <section class="hero" style="padding-block: var(--space-16);">
    <div class="hero__inner">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" style="justify-content: center; color: rgba(255,255,255,0.6);">
          <li><a href="/Pilot.BM/" style="color: rgba(255,255,255,0.6);">Home</a></li>
          <li class="breadcrumb__sep" aria-hidden="true">›</li>
          <li><a href="/Pilot.BM/directory" style="color: rgba(255,255,255,0.6);">Directory</a></li>
          <li class="breadcrumb__sep" aria-hidden="true">›</li>
          <li style="color: rgba(255,255,255,0.9);">Claim a Listing</li>
        </ol>
      </nav>
      <h1 class="hero-title">Claim Your Listing</h1>
      <p class="hero-subtitle">
        Be found by the visitors, movers, and residents who need what you offer.
      </p>
    </div>
  </section>

  <div class="container" style="padding-block: var(--space-12);">

    <!-- Directory reach note -->
    <section style="max-width: 680px; margin: 0 auto var(--space-12); text-align: center;">
      <p style="color: var(--color-ink); line-height: 1.75;">
        Pilot.BM serves the three audiences with the highest intent to spend in Bermuda:
        visitors planning a trip, people in the process of relocating, and residents
        looking for trusted local businesses. A listing here is not a number in a national
        directory — it is placement in the guide people use specifically for Bermuda decisions.
      </p>
      <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-3);">
        Note: directory listings are live from day one. Affiliate network indexing typically
        takes 4–8 weeks to propagate fully — this is a normal lag and does not affect
        your listing's visibility on Pilot.BM itself.
      </p>
    </section>

    <!-- How claiming works -->
    <section style="margin-bottom: var(--space-12);">
      <h2 style="font-size: var(--text-2xl); text-align: center; margin-bottom: var(--space-8);">How claiming works</h2>
      <div class="card-grid card-grid-3" style="max-width: 860px; margin: 0 auto;">
        <div style="text-align: center; padding: var(--space-6);">
          <div style="width: 48px; height: 48px; border-radius: 50%; background-color: var(--color-ocean); color: white; font-family: var(--font-serif); font-size: var(--text-xl); font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">1</div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-2);">Submit the claim form</h3>
          <p style="font-size: var(--text-sm); color: var(--color-ink); line-height: 1.7;">
            Fill in your business name, email address, and the tier you are interested in.
            Select Free to get listed at no cost, or indicate a paid tier to discuss next steps.
          </p>
        </div>
        <div style="text-align: center; padding: var(--space-6);">
          <div style="width: 48px; height: 48px; border-radius: 50%; background-color: var(--color-ocean); color: white; font-family: var(--font-serif); font-size: var(--text-xl); font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">2</div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-2);">We verify ownership</h3>
          <p style="font-size: var(--text-sm); color: var(--color-ink); line-height: 1.7;">
            We confirm you are the business owner or an authorised representative, typically
            via email domain match or a short exchange. This keeps listings accurate.
          </p>
        </div>
        <div style="text-align: center; padding: var(--space-6);">
          <div style="width: 48px; height: 48px; border-radius: 50%; background-color: var(--color-ocean); color: white; font-family: var(--font-serif); font-size: var(--text-xl); font-weight: 700; display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-4);">3</div>
          <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-2);">Upgrade any time</h3>
          <p style="font-size: var(--text-sm); color: var(--color-ink); line-height: 1.7;">
            Start free and upgrade when you are ready. Tier changes take effect at the next
            billing cycle. You are never locked in.
          </p>
        </div>
      </div>
    </section>

    <!-- Tier pricing table -->
    <section style="margin-bottom: var(--space-12);">
      <h2 style="font-size: var(--text-2xl); text-align: center; margin-bottom: var(--space-3);">Choose your tier</h2>
      <p style="text-align: center; color: var(--color-muted); margin-bottom: var(--space-10); max-width: 560px; margin-left: auto; margin-right: auto;">
        All tiers include a verified listing in the Pilot.BM directory. Paid tiers include
        enhanced placement, richer profiles, and partner benefits.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-6); margin-bottom: var(--space-4);">

        <!-- Free tier -->
        <div class="card" style="display: flex; flex-direction: column;">
          <div style="margin-bottom: var(--space-5);">
            <span class="badge badge-tier-free" style="margin-bottom: var(--space-4); display: inline-block;">Free</span>
            <p style="font-family: var(--font-serif); font-size: var(--text-4xl); margin-bottom: 0; line-height: 1;">$0</p>
            <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-1);">per month</p>
          </div>
          <ul style="padding-left: var(--space-5); font-size: var(--text-sm); color: var(--color-ink); flex: 1; display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-6);">
            <li>Listed in the Pilot.BM directory</li>
            <li>Business name and category</li>
            <li>Parish shown</li>
            <li>Verified badge on your listing</li>
            <li style="color: var(--color-muted);">No description or contact details</li>
            <li style="color: var(--color-muted);">Standard alphabetical placement</li>
          </ul>
          <a href="mailto:claim@pilot.bm?subject=Free%20listing%20claim"
             class="btn btn-ghost btn-sm"
             style="text-align: center; width: 100%;">
            Claim free listing
          </a>
        </div>

        <!-- Standard tier -->
        <div class="card" style="display: flex; flex-direction: column;">
          <div style="margin-bottom: var(--space-5);">
            <span class="badge badge-tier-standard" style="margin-bottom: var(--space-4); display: inline-block;">Standard</span>
            <p style="font-family: var(--font-serif); font-size: var(--text-4xl); margin-bottom: 0; line-height: 1;">$30</p>
            <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-1);">per month</p>
          </div>
          <ul style="padding-left: var(--space-5); font-size: var(--text-sm); color: var(--color-ink); flex: 1; display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-6);">
            <li>Everything in Free</li>
            <li>Full business description</li>
            <li>Phone number</li>
            <li>Website URL (dofollow link)</li>
            <li>Hours of operation</li>
            <li style="color: var(--color-muted);">Standard category placement</li>
            <li style="color: var(--color-muted);">No photos or Partner badge</li>
          </ul>
          <div style="margin-top: auto;">
            <button class="btn btn-secondary btn-sm" style="width: 100%; margin-bottom: var(--space-2);"
                    onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
              Get Standard
            </button>
            <p style="font-size: var(--text-xs); color: var(--color-amber); text-align: center; margin: 0;">
              [TODO: Wire Stripe Checkout — replace this button with the Stripe Payment Link
              for the Standard tier once your Stripe account is set up.
              See docs/monetization.md for integration instructions.]
            </p>
          </div>
        </div>

        <!-- Featured tier -->
        <div class="card card-elevated" style="display: flex; flex-direction: column; border-color: var(--color-tier-featured); border-width: 2px; position: relative;">
          <div style="position: absolute; top: -1px; left: 50%; transform: translateX(-50%); background-color: var(--color-tier-featured); color: white; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: var(--space-1) var(--space-3); border-radius: 0 0 var(--radius-sm) var(--radius-sm); white-space: nowrap;">
            Most popular
          </div>
          <div style="margin-bottom: var(--space-5); margin-top: var(--space-3);">
            <span class="badge badge-tier-featured" style="margin-bottom: var(--space-4); display: inline-block;">Featured</span>
            <p style="font-family: var(--font-serif); font-size: var(--text-4xl); margin-bottom: 0; line-height: 1;">$50</p>
            <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-1);">per month</p>
          </div>
          <ul style="padding-left: var(--space-5); font-size: var(--text-sm); color: var(--color-ink); flex: 1; display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-6);">
            <li>Everything in Standard</li>
            <li>Photos (up to 3)</li>
            <li>Top-of-category placement</li>
            <li>"Pilot.BM Partner" badge</li>
            <li>Deals and promotions field</li>
            <li style="color: var(--color-muted);">Not eligible for homepage spotlight</li>
          </ul>
          <div style="margin-top: auto;">
            <button class="btn btn-primary btn-sm" style="width: 100%; margin-bottom: var(--space-2);"
                    onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
              Get Featured
            </button>
            <p style="font-size: var(--text-xs); color: var(--color-amber); text-align: center; margin: 0;">
              [TODO: Wire Stripe Checkout — replace this button with the Stripe Payment Link
              for the Featured tier once your Stripe account is set up.
              See docs/monetization.md for integration instructions.]
            </p>
          </div>
        </div>

        <!-- Anchor tier -->
        <div class="card" style="display: flex; flex-direction: column; border-color: var(--color-tier-anchor); border-width: 2px;">
          <div style="margin-bottom: var(--space-5);">
            <span class="badge badge-tier-anchor" style="margin-bottom: var(--space-4); display: inline-block;">Anchor</span>
            <p style="font-family: var(--font-serif); font-size: var(--text-4xl); margin-bottom: 0; line-height: 1;">$100</p>
            <p style="color: var(--color-muted); font-size: var(--text-sm); margin-top: var(--space-1);">per month</p>
          </div>
          <ul style="padding-left: var(--space-5); font-size: var(--text-sm); color: var(--color-ink); flex: 1; display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-6);">
            <li>Everything in Featured</li>
            <li>Homepage spotlight eligibility</li>
            <li>Category sponsorship (lead position)</li>
            <li>Featured in relevant Pilot.BM editorial</li>
            <li>Deals published on /live/deals page</li>
            <li>"Anchor Partner" badge</li>
          </ul>
          <div style="margin-top: auto;">
            <button class="btn btn-secondary btn-sm" style="width: 100%; margin-bottom: var(--space-2);"
                    onclick="document.getElementById('claim-form').scrollIntoView({behavior:'smooth'})">
              Get Anchor
            </button>
            <p style="font-size: var(--text-xs); color: var(--color-amber); text-align: center; margin: 0;">
              [TODO: Wire Stripe Checkout — replace this button with the Stripe Payment Link
              for the Anchor tier once your Stripe account is set up.
              See docs/monetization.md for integration instructions.]
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- Claim form -->
    <section id="claim-form" style="max-width: 580px; margin: 0 auto;">
      <div id="form-view">
        <h2 style="text-align: center; font-size: var(--text-2xl); margin-bottom: var(--space-2);">Submit your claim</h2>
        <p style="text-align: center; color: var(--color-muted); margin-bottom: var(--space-8);">
          We'll review your submission and be in touch within 24 hours.
        </p>

        <!-- TODO: wire this form to your preferred form processor (Netlify Forms, Formspree, etc.)
             For Netlify Forms: add data-netlify="true" and name="claim" to the form element.
             For Formspree: set action="https://formspree.io/f/YOUR_FORM_ID" method="POST".
             The onsubmit="return false" below is a placeholder — remove it when wiring real submission. -->
        <form
          id="claim-submission"
          style="display: flex; flex-direction: column; gap: var(--space-5);"
          onsubmit="return false;"
        >

          <div>
            <label for="biz-name"
              style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Business name *
            </label>
            <input
              type="text"
              id="biz-name"
              name="business_name"
              required
              placeholder="Your business name"
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); box-sizing: border-box;"
            />
          </div>

          <div>
            <label for="biz-website"
              style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Business website
            </label>
            <input
              type="url"
              id="biz-website"
              name="business_website"
              placeholder="https://yourbusiness.bm"
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); box-sizing: border-box;"
            />
          </div>

          <div>
            <label for="biz-email"
              style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Your email address *
            </label>
            <input
              type="email"
              id="biz-email"
              name="contact_email"
              required
              placeholder="you@yourbusiness.bm"
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); box-sizing: border-box;"
            />
            <p style="font-size: var(--text-xs); color: var(--color-muted); margin-top: var(--space-1);">
              Using your business domain email speeds up ownership verification.
            </p>
          </div>

          <div>
            <label for="biz-category"
              style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Business category *
            </label>
            <select
              id="biz-category"
              name="category"
              required
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); background-color: var(--color-white); box-sizing: border-box;"
            >
              <option value="">Select a category...</option>
              <option value="restaurant">Restaurant / Bar / Cafe</option>
              <option value="accommodation">Accommodation</option>
              <option value="retail">Retail</option>
              <option value="professional">Professional Services</option>
              <option value="health">Health and Wellness</option>
              <option value="education">Education</option>
              <option value="insurance">Insurance and Finance</option>
              <option value="real-estate">Real Estate</option>
              <option value="tourism">Tourism and Activities</option>
              <option value="transport">Transport</option>
              <option value="trades">Trades and Construction</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="biz-tier"
              style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Tier you're interested in *
            </label>
            <select
              id="biz-tier"
              name="tier"
              required
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); background-color: var(--color-white); box-sizing: border-box;"
            >
              <option value="">Select a tier...</option>
              <option value="free">Free — name and category listing ($0/month)</option>
              <option value="standard">Standard — full profile with contact details ($30/month)</option>
              <option value="featured">Featured — photos, top placement, Partner badge ($50/month)</option>
              <option value="anchor">Anchor — homepage spotlight, editorial, deals page ($100/month)</option>
            </select>
          </div>

          <div>
            <label for="biz-notes"
              style="display: block; font-weight: 600; font-size: var(--text-sm); margin-bottom: var(--space-2);">
              Anything else we should know?
            </label>
            <textarea
              id="biz-notes"
              name="notes"
              rows="3"
              placeholder="e.g. We already have a basic listing that needs updating, we're a new business opening in October, etc."
              style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: var(--text-sm); resize: vertical; box-sizing: border-box;"
            ></textarea>
          </div>

          <!-- Phase 1 billing note -->
          <div style="background-color: var(--color-amber-muted); border: 1px solid var(--color-amber); border-radius: var(--radius-md); padding: var(--space-3) var(--space-4);">
            <p style="font-size: var(--text-xs); color: #92400e; margin: 0;">
              <strong>Payment processing is not yet live (Phase 1).</strong>
              For paid tiers, we'll be in touch with payment instructions after verifying your
              submission. Automated Stripe billing launches in Phase 2.
            </p>
          </div>

          <button type="button" id="submit-claim" class="btn btn-primary btn-lg" style="width: 100%;">
            Submit claim →
          </button>
        </form>
      </div>

      <!-- Thank you state -->
      <div id="thankyou-view" style="display: none; text-align: center; padding: var(--space-12) var(--space-6);">
        <div style="width: 56px; height: 56px; border-radius: 50%; background-color: var(--color-ocean); color: white; font-size: var(--text-2xl); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-5);">
          &#10003;
        </div>
        <h2 style="margin-bottom: var(--space-3);">Claim received</h2>
        <p style="color: var(--color-muted); margin-bottom: var(--space-2);">
          We'll review your submission and be in touch within 24 hours at the email you provided.
        </p>
        <p style="color: var(--color-muted); font-size: var(--text-sm); margin-bottom: var(--space-8);">
          Your listing will appear in the directory once ownership is confirmed.
          If you selected a paid tier, we'll follow up with payment details.
        </p>
        <a href="/Pilot.BM/directory" class="btn btn-secondary">Back to directory</a>
      </div>
    </section>

  </div>
</Base>

<script>
  document.getElementById('submit-claim')?.addEventListener('click', () => {
    const form = document.getElementById('claim-submission') as HTMLFormElement
    if (!form) return

    const name = (document.getElementById('biz-name') as HTMLInputElement)?.value?.trim()
    const email = (document.getElementById('biz-email') as HTMLInputElement)?.value?.trim()
    const tier = (document.getElementById('biz-tier') as HTMLSelectElement)?.value
    const category = (document.getElementById('biz-category') as HTMLSelectElement)?.value

    if (!name || !email || !tier || !category) {
      alert('Please fill in all required fields.')
      return
    }

    // Phase 2: POST to API or form processor endpoint.
    // For now: show thank-you state client-side.
    const formView = document.getElementById('form-view')
    const thankYou = document.getElementById('thankyou-view')
    if (formView) formView.style.display = 'none'
    if (thankYou) thankYou.style.display = 'block'
    window.scrollTo({ top: 0, behavior: 'smooth' })
  })
</script>
