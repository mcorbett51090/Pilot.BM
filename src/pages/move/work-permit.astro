<Base
  title="Bermuda Work Permits — What You Need to Know"
  description="How Bermuda work permits work: employer sponsorship, the job advertising requirement, EIRC investor pathway, and what the Work From Bermuda closure means for you."
>
  <section class="hero hero--image" style="padding-block: var(--space-16); --hero-image: url('/Pilot.BM/images/seascape.webp');">
    <div class="hero__inner">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb" style="justify-content: center; color: rgba(255,255,255,0.6);">
          <li><a href="/Pilot.BM/" style="color: rgba(255,255,255,0.6);">Home</a></li>
          <li class="breadcrumb__sep" aria-hidden="true">›</li>
          <li><a href="/Pilot.BM/move" style="color: rgba(255,255,255,0.6);">Moving</a></li>
