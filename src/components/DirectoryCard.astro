---
import type { CollectionEntry } from 'astro:content'

interface Props {
  listing: CollectionEntry<'directory'>
}

const { listing } = Astro.props
const { data } = listing

const tierLabels: Record<string, string> = {
  free: 'Free',
  standard: 'Standard',
  featured: 'Featured',
  anchor: 'Anchor',
}

const categoryLabels: Record<string, string> = {
  accommodation: 'Accommodation',
  attraction: 'Attraction',
  restaurant: 'Restaurant',
  retail: 'Retail',
  transport: 'Transport',
  real_estate: 'Real Estate',
  insurance: 'Insurance',
  relocation: 'Relocation',
  education: 'Education',
  tourism: 'Tourism',
  dining_event: 'Dining Event',
  financial: 'Financial',
  legal: 'Legal',
  healthcare: 'Healthcare',
  other: 'Other',
}

const isPartner = data.tier === 'featured' || data.tier === 'anchor'
const cardClass = [
  'directory-card',
  data.tier === 'featured' ? 'directory-card--featured' : '',
  data.tier === 'anchor' ? 'directory-card--anchor' : '',
]
  .filter(Boolean)
  .join(' ')

// LocalBusiness schema type mapping
const schemaTypeMap: Record<string, string> = {
  accommodation: 'LodgingBusiness',
  restaurant: 'Restaurant',
  dining_event: 'FoodEstablishment',
  attraction: 'TouristAttraction',
  transport: 'LocalBusiness',
  real_estate: 'RealEstateAgent',
  insurance: 'InsuranceAgency',
  financial: 'FinancialService',
  healthcare: 'MedicalOrganization',
  education: 'EducationalOrganization',
  relocation: 'LocalBusiness',
  retail: 'Store',
  tourism: 'TouristInformationCenter',
  legal: 'LegalService',
  other: 'LocalBusiness',
}

const schemaType = schemaTypeMap[data.category] ?? 'LocalBusiness'
const ldJson = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: data.name,
  description: data.description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: data.parish,
    addressCountry: 'BM',
  },
  ...(data.phone ? { telephone: data.phone } : {}),
  ...(data.url ? { url: data.url } : {}),
  ...(data.hours ? { openingHours: data.hours } : {}),
}
---

<article class={cardClass}>
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  <div class="directory-card__header">
    <div>
      <h3 class="directory-card__name">{data.name}</h3>
      <div class="directory-card__meta">
        <span class={`badge badge-tier-${data.tier}`}>{tierLabels[data.tier]}</span>
        <span class="badge badge-category">{categoryLabels[data.category] ?? data.category}</span>
        <span style="font-size: var(--text-xs); color: var(--color-muted);">{data.parish}</span>
      </div>
    </div>
    {isPartner && (
      <span class="badge badge-partner" style="flex-shrink: 0;">Pilot.BM Partner</span>
    )}
  </div>

  <p class="directory-card__desc">{data.description.slice(0, 200)}{data.description.length > 200 ? '…' : ''}</p>

  <div class="directory-card__contact">
    {data.url && (
      <a href={data.url} rel="noopener nofollow" target="_blank">
        Visit website →
      </a>
    )}
    {data.phone && (
      <a href={`tel:${data.phone.replace(/\s/g, '')}`}>{data.phone}</a>
    )}
    {data.hours && (
      <span style="font-size: var(--text-xs); color: var(--color-muted);">{data.hours}</span>
    )}
  </div>
</article>
