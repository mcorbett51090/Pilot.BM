---
const currentPath = Astro.url.pathname

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/'
  return currentPath.startsWith(path)
}
---

<nav class="nav" aria-label="Main navigation">
  <!-- CSS-only mobile menu toggle -->
  <input type="checkbox" id="nav-toggle" class="visually-hidden" aria-hidden="true" />

  <div class="nav__inner">
    <a href="/Pilot.BM/" class="nav-logo" aria-label="Pilot.BM — Home">Pilot.BM</a>

    <ul class="nav-links" role="list">
      <li>
        <a
          href="/Pilot.BM/visit"
          class="nav-link"
          aria-current={isActive('/visit') ? 'page' : undefined}
        >
          Visiting
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/move"
          class="nav-link"
          aria-current={isActive('/move') ? 'page' : undefined}
        >
          Moving
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/live"
          class="nav-link"
          aria-current={isActive('/live') ? 'page' : undefined}
        >
          Living
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/live/news"
          class="nav-link"
          aria-current={isActive('/live/news') ? 'page' : undefined}
        >
          News
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/directory"
          class="nav-link"
          aria-current={isActive('/directory') ? 'page' : undefined}
        >
          Directory
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/search"
          class="nav-link nav-search-icon"
          aria-label="Search Pilot.BM"
          aria-current={isActive('/search') ? 'page' : undefined}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <span class="nav-search-icon__text">Search</span>
        </a>
      </li>
    </ul>

    <label for="nav-toggle" class="nav-hamburger" aria-label="Toggle navigation menu">
      <span class="hamburger-bar hamburger-bar--top"></span>
      <span class="hamburger-bar hamburger-bar--mid"></span>
      <span class="hamburger-bar hamburger-bar--bot"></span>
    </label>
  </div>

  <!-- Mobile menu — shown when checkbox checked -->
  <div class="nav-mobile" role="navigation" aria-label="Mobile navigation">
    <a
      href="/Pilot.BM/visit"
      class="nav-link nav-link--mobile"
      aria-current={isActive('/visit') ? 'page' : undefined}
    >
      Visiting
    </a>
    <a
      href="/Pilot.BM/move"
      class="nav-link nav-link--mobile"
      aria-current={isActive('/move') ? 'page' : undefined}
    >
      Moving
    </a>
    <a
      href="/Pilot.BM/live"
      class="nav-link nav-link--mobile"
      aria-current={isActive('/live') ? 'page' : undefined}
    >
      Living
    </a>
    <a
      href="/Pilot.BM/live/news"
      class="nav-link nav-link--mobile"
      aria-current={isActive('/live/news') ? 'page' : undefined}
    >
      News
    </a>
    <a
      href="/Pilot.BM/directory"
      class="nav-link nav-link--mobile"
      aria-current={isActive('/directory') ? 'page' : undefined}
    >
      Directory
    </a>
    <a
      href="/Pilot.BM/search"
      class="nav-link nav-link--mobile"
      aria-current={isActive('/search') ? 'page' : undefined}
    >
      Search
    </a>
  </div>
</nav>

<style>
  /* Show mobile menu when checkbox is checked */
  :global(#nav-toggle:checked ~ .nav-mobile) {
    display: flex;
  }

  /* Search icon link in desktop nav: icon + visually-hidden-ish label */
  :global(.nav-search-icon) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  /* The word "Search" is hidden on wider screens (icon carries it) but
     read by screen readers via the aria-label; kept for medium widths. */
  :global(.nav-search-icon__text) {
    font-size: var(--text-sm);
  }

  @media (min-width: 900px) {
    :global(.nav-search-icon__text) {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  /* The icon's underline indicator would look odd under an SVG; suppress it. */
  :global(.nav-search-icon::after) {
    display: none;
  }

  /* --- Hamburger to X animation --------------------------- */

  /* Top bar: rotate +45deg and translate down to center */
  :global(#nav-toggle:checked ~ .nav__inner .hamburger-bar--top) {
    transform: translateY(7px) rotate(45deg);
  }

  /* Middle bar: fade out and collapse */
  :global(#nav-toggle:checked ~ .nav__inner .hamburger-bar--mid) {
    opacity: 0;
    transform: scaleX(0);
  }

  /* Bottom bar: rotate -45deg and translate up to center */
  :global(#nav-toggle:checked ~ .nav__inner .hamburger-bar--bot) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Hamburger bar base styles + transitions */
  :global(.hamburger-bar) {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-ink);
    transition:
      transform 200ms ease,
      opacity 150ms ease;
    transform-origin: center;
  }

  /* Hamburger touch target */
  :global(.nav-hamburger) {
    padding: var(--space-3);
    min-width: 44px;
    min-height: 44px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
  }

  /* Mobile menu container polish */
  :global(.nav-mobile) {
    padding: var(--space-2) var(--space-4) var(--space-4);
    gap: 0;
  }

  /* --- Mobile nav link touch targets -------------------- */
  :global(.nav-link--mobile) {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding-block: var(--space-3);
    padding-inline: var(--space-2);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-border);
  }

  :global(.nav-link--mobile:last-child) {
    border-bottom: none;
  }

  :global(.nav-link--mobile:hover) {
    color: var(--color-ocean);
    background-color: var(--color-ocean-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  :global(.nav-link--mobile[aria-current='page']) {
    color: var(--color-ocean);
    font-weight: 600;
    background-color: var(--color-ocean-muted);
    border-radius: var(--radius-sm);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    :global(.hamburger-bar) {
      transition: none;
    }
  }
</style>
