---
const currentPath = Astro.url.pathname

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/'
  return currentPath.startsWith(path)
}
---

<nav class="nav" aria-label="Main navigation">
  <!-- CSS-only mobile menu toggle -->
  <input type="checkbox" id="nav-toggle" class="visually-hidden" aria-hidden="true" />

  <div class="nav__inner">
    <a href="/Pilot.BM/" class="nav-logo" aria-label="Pilot.BM — Home">Pilot.BM</a>

    <ul class="nav-links" role="list">
      <li>
        <a
          href="/Pilot.BM/visit"
          class="nav-link"
          aria-current={isActive('/visit') ? 'page' : undefined}
        >
          Visiting
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/move"
          class="nav-link"
          aria-current={isActive('/move') ? 'page' : undefined}
        >
          Moving
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/live"
          class="nav-link"
          aria-current={isActive('/live') ? 'page' : undefined}
        >
          Living
        </a>
      </li>
      <li>
        <a
          href="/Pilot.BM/directory"
          class="nav-link"
          aria-current={isActive('/directory') ? 'page' : undefined}
        >
          Directory
        </a>
      </li>
    </ul>

    <label for="nav-toggle" class="nav-hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </label>
  </div>

  <!-- Mobile menu — shown when checkbox checked -->
  <div class="nav-mobile" role="navigation" aria-label="Mobile navigation">
    <a
      href="/Pilot.BM/visit"
      class="nav-link"
      aria-current={isActive('/visit') ? 'page' : undefined}
    >
      Visiting
    </a>
    <a
      href="/Pilot.BM/move"
      class="nav-link"
      aria-current={isActive('/move') ? 'page' : undefined}
    >
      Moving
    </a>
    <a
      href="/Pilot.BM/live"
      class="nav-link"
      aria-current={isActive('/live') ? 'page' : undefined}
    >
      Living
    </a>
    <a
      href="/Pilot.BM/directory"
      class="nav-link"
      aria-current={isActive('/directory') ? 'page' : undefined}
    >
      Directory
    </a>
  </div>
</nav>

<style>
  #nav-toggle:checked ~ .nav-mobile {
    display: flex;
  }
</style>
