---
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">Pilot.BM</a>
        <p class="footer__tagline">Bermuda, honestly.</p>
        <p style="font-size: var(--text-sm); line-height: 1.6; color: rgba(255,255,255,0.5); margin-bottom: 0;">
          An independent guide for discerning visitors,
          people making the move, and those who call it home.
          Not affiliated with the Bermuda Tourism Authority or
          the Bermuda Government.
        </p>
      </div>

      <!-- Visitors -->
      <div>
        <p class="footer__col-title">Visitors</p>
        <ul class="footer__links" role="list">
          <li><a href="/visit/getting-around">Getting Around</a></li>
          <li><a href="/visit/beaches">Beaches</a></li>
          <li><a href="/visit/eat">Eat &amp; Drink</a></li>
          <li><a href="/visit/stay">Where to Stay</a></li>
          <li><a href="/visit/do">Things to Do</a></li>
          <li><a href="/visit/itineraries">Itineraries</a></li>
        </ul>
      </div>

      <!-- Movers -->
      <div>
        <p class="footer__col-title">Moving</p>
        <ul class="footer__links" role="list">
          <li><a href="/move/work-permit">Work Permits</a></li>
          <li><a href="/move/cost-of-living">Cost of Living</a></li>
          <li><a href="/move/healthcare">Healthcare</a></li>
          <li><a href="/move/schools">Schools</a></li>
          <li><a href="/move/banking">Banking</a></li>
          <li><a href="/move/tools/assessment-number">Car &amp; Assessment Numbers</a></li>
          <li><a href="/move/tools/compensation">Compensation Calculator</a></li>
          <li><a href="/move/tools/pathway">Immigration Pathway Finder</a></li>
        </ul>
      </div>

      <!-- Residents + Directory -->
      <div>
        <p class="footer__col-title">Living Here</p>
        <ul class="footer__links" role="list">
          <li><a href="/live/events">Events Calendar</a></li>
          <li><a href="/live/deals">Local Deals</a></li>
          <li><a href="/directory">Browse Directory</a></li>
          <li><a href="/directory/claim">Claim a Listing</a></li>
          <li><a href="/about">About Pilot.BM</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <div>
        <div class="footer__legal">
          <a href="/legal/terms">Terms</a>
          <a href="/legal/privacy">Privacy</a>
          <a href="/legal/disclaimer">Disclaimer</a>
          <a href="/legal/affiliate-disclosure">Affiliate Disclosure</a>
        </div>
        <p class="footer__disclaimer" style="margin-top: var(--space-3);">
          Not legal advice — verify current regulations at
          <a href="https://www.gov.bm" style="color: rgba(255,255,255,0.5);" rel="noopener">gov.bm</a>.
          Some links are affiliate links; we may earn a commission at no cost to you.
          See our <a href="/legal/affiliate-disclosure" style="color: rgba(255,255,255,0.5);">affiliate disclosure</a>.
        </p>
      </div>
      <p style="font-size: var(--text-xs); color: rgba(255,255,255,0.3); white-space: nowrap;">
        &copy; {year} Pilot.BM
      </p>
    </div>
  </div>
</footer>
